# Frontend config
# Base path prefix for backend APIs
VITE_API_PREFIX=/api/v1

# Optional: call API on a different origin (e.g. https://api.example.com)
# Leave empty for same-origin
VITE_API_ORIGIN=

# Vite dev server proxy target (only used during `npm run dev`)
# Example: http://localhost:8000
VITE_BACKEND_URL=http://localhost:8000

# If true, users must log in before accessing the UI.
# If false, users can access chat without logging in.
VITE_REQUIRE_GUEST_AUTH=true
